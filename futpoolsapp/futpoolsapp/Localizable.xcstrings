    "social.q1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Way better than the WhatsApp group chat. Zero arguments over points. We're 3 pools in with the work crew already.”"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Por fin algo mejor que el grupo de WhatsApp. Cero discusiones por puntos. Llevo 3 quinielas con el equipo del trabajo.»"
          }
        }
      }
    },
    "social.q2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Got hooked on the Daily Pick. Morning coffee, my forecast, and that's the day. 14-day streak going.”"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Me enganché al Pick del Día. Café de la mañana, mi pronóstico, y arranca el día. Llevo 14 días seguidos.»"
          }
        }
      }
    },
    "social.q3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“The best part: nobody has to chase anyone for $50. The app charges, tracks the score, and pays the winner.”"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Lo mejor: ya nadie tiene que andar cobrando los $50. La app cobra, lleva la cuenta y le paga al que gana.»"
          }
        }
      }
    },
    "social.q4" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Challenged my brother in the Clásico, beat him, gift card landed the next day. No funny business.”"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Reté a mi hermano en el Clásico, le gané y la gift card me llegó al día siguiente. Sin trampas.»"
          }
        }
      }
    },
    "social.q5" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Clean interface, the rules click on the first read. Way better than running pools in an Excel sheet.”"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«La interfaz está limpia y las reglas se entienden a la primera. Mucho mejor que llevar la quiniela en un Excel.»"
          }
        }
      }
    },
    "sol.excelChaos" : {
