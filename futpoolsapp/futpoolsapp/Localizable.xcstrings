          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si un sorteo no alcanza el número mínimo de entradas mostrado en su pantalla de detalle al momento del cierre, el sorteo se cancela y todos los Tickets son reembolsados. No se otorga premio."
          }
        }
      }
    },
