    "\"At last, no fights with my buddies over weekend points. I won a $250 gift card.\"": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"At last, no fights with my buddies over weekend points. I won a $250 gift card.\""
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Por fin no peleo con mis cuates por los puntos del fin. Me llevé una gift card de $250.\""
          }
        }
      }
    },
