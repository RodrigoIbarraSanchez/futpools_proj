    "%1$lld prize + %2$lld platform fee. If pool doesn't reach min players, you get a full refund.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld prize + %2$lld platform fee. If pool doesn't reach min players, you get a full refund."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld de premio + %2$lld de comisión. Si no se alcanza el mínimo de jugadores, te reembolsamos todo."
