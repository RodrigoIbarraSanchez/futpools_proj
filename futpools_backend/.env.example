PORT=3000
MONGODB_URI=mongodb://localhost:27017/futpools
JWT_SECRET=your-super-secret-jwt-key-change-in-production
API_FOOTBALL_KEY=your-api-football-key
API_FOOTBALL_SEASON=2025
# JSON map: league code or name -> API-Football league id (optional override)
API_FOOTBALL_LEAGUES={"LIGA_MX":262}
# JSON map: league code or name -> country (used to resolve league id)
API_FOOTBALL_LEAGUE_COUNTRIES={"Liga MX":"Mexico","Premier League":"England","La Liga":"Spain","Serie A":"Italy","Bundesliga":"Germany","Ligue 1":"France","Brasileirao":"Brazil","Primeira Liga":"Portugal","Eredivisie":"Netherlands","Major League Soccer":"USA"}
API_FOOTBALL_POLL_MS=30000

# Public URL of the frontend (used by OG share pages to redirect users to the SPA after bots read the meta tags).
FRONTEND_URL=https://futpools.com

# Optional: API key for updating app settings (e.g. banner URL) from the dashboard. If set, PUT /settings requires X-API-Key header.
SETTINGS_API_KEY=

# AdMob Server-Side Verification (Tickets v2.4 — Fase 3 rewarded ads).
# Override the default Google verifier-keys URL for testing or when
# pinning to a specific key generation. Empty = use the live public URL.
ADMOB_SSV_KEYS_URL=
# Set NODE_ENV=production in Render to disable the dev-credit endpoint.
# In dev/staging it stays open so iOS simulator builds can credit Tickets
# without wiring real AdMob credentials.
NODE_ENV=development

# === simple_version branch ===
# When unset, server runs in legacy "master" mode (coins + tickets + IAP routes
# all mounted). When set to "true", switches to simple_version: only paid pools
# via Stripe MXN, no coin shop, no challenges, no sweepstakes, no daily-pick
# routes mounted, no balance/tickets in /users/me response, POST /quinielas
# gated to ADMIN_EMAILS.
FUTPOOLS_SIMPLE_MODE=false

# Stripe per-pool entry checkout (Phase 2). $50 MXN default per entry,
# editable per pool by the admin via Quiniela.entryFeeMXN.
# Reuses the existing STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET — the
# same /payments/webhook handler dispatches by session.metadata: a session
# with metadata.poolId becomes a pool entry, one with metadata.packId
# becomes a coin pack credit. ONE Stripe webhook config covers both flows.

# Where Stripe redirects after checkout (success/cancel). In dev set to
# http://localhost:5174 ; in prod set to https://futpools.com (or simple
# subdomain if running parallel deployments).
WEB_APP_BASE_URL=http://localhost:5174

# === APNs (push notifications) ===
# Apple Developer Portal → Keys → "+" with "Apple Push Notifications service
# (APNs)" checked. Download the .p8 and paste its contents here (multi-line,
# including the BEGIN/END lines). In Render, paste with literal \n preserved
# or use a secret file — pushService normalizes "\n" back to real newlines.
#
# TEAM SCOPING: APNs auth keys are per Apple-team. The App Store build ships
# under bundle com.crypto-price-alert.crypto-price-alert, which belongs to
# team 5UXBMT84FP — so for PRODUCTION pushes these three must come from THAT
# team's key. (The futpools-branded build is team 5KF2W3R568; if you ever
# publish it too, you'd add a second key.) The apns-topic per push is taken
# from the device token's stored bundleId, so the backend already routes to
# whichever app the token came from — only the auth key/team must match.
APNS_KEY_P8=
APNS_KEY_ID=               # 10-char identifier shown next to the key
APNS_TEAM_ID=5UXBMT84FP    # team that owns the shipping bundle (crypto-price-alert)
APNS_BUNDLE_ID=com.crypto-price-alert.crypto-price-alert  # fallback apns-topic; per-token bundleId overrides
# false = sandbox (TestFlight + DEBUG builds); true = production gateway.
# (Informational — pushService picks the gateway per token.environment.)
APNS_PRODUCTION=false
